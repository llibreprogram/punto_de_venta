// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums
enum OrderStatus {
  ABIERTO
  PAGADO
  CANCELADO
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
}

enum ItemStatus {
  PENDIENTE
  EN_PROCESO
  LISTO
}

// Modelos principales
model Categoria {
  id        Int       @id @default(autoincrement())
  nombre    String
  activa    Boolean   @default(true)
  productos Producto[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Producto {
  id          Int       @id @default(autoincrement())
  nombre      String
  precioCents Int       // precio en centavos
  costoCents  Int       @default(0) // costo unitario en centavos
  ingredientes Json?
  extras       Json?
  sku         String?   @unique
  activo      Boolean   @default(true)
  requiereCocina Boolean @default(true)
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  categoriaId Int
  imagenUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  items       PedidoItem[]
  integrationMappings IntegrationMapping[]
  recetaItems         RecetaItem[]
}

model Mesa {
  id        Int       @id @default(autoincrement())
  nombre    String    @unique
  activa    Boolean   @default(true)
  pedidos   Pedido[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Pedido {
  id          Int          @id @default(autoincrement())
  numero      Int          @unique
  estado      OrderStatus  @default(ABIERTO)
  mesa        Mesa?        @relation(fields: [mesaId], references: [id])
  mesaId      Int?
  subCuenta   Int          @default(1) // número de sub-cuenta dentro de la mesa
  nombreCuenta String?     // nombre personalizado para la sub-cuenta
  items       PedidoItem[]
  subtotalCents  Int
  impuestoCents  Int        @default(0)
  itebisCents    Int        @default(0)
  propinaCents   Int        @default(0)
  descuentoCents Int        @default(0)
  totalCents     Int
  pagos       Pago[]
  notas       String?
  platform        String?       // "local", "ubereats", "pedidosya"
  platformOrderId String?       // ID externo de la orden, ej. "U-8821"
  externalStatus  String?       // Estado externo, ej. "PENDING", "PREPARING"
  driverName      String?       // Nombre del motorista si la plataforma lo envía
  driverEta       Int?          // ETA del motorista en minutos
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ticketAccesses TicketAccess[]
  usuarioId   Int?          // Empleado que registró la orden
  usuario     Usuario?      @relation(fields: [usuarioId], references: [id])
  ncf            String?
  ncfTipo        String?
  registroFiscal RegistroFiscal?
}

model PedidoItem {
  id         Int      @id @default(autoincrement())
  pedido     Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId   Int
  producto   Producto @relation(fields: [productoId], references: [id])
  productoId Int
  cantidad   Int      @default(1)
  precioCents Int     // precio unitario al momento de la venta (centavos)
  costoCents  Int     @default(0) // costo unitario al momento de la venta (centavos)
  totalCents  Int
  notas      String?
  removidos  Json?
  extras     Json?
  extrasCents Int     @default(0) // suma de extras por unidad en centavos
  estado     ItemStatus @default(PENDIENTE)
  inventarioDescontado Boolean @default(false)
}

model Pago {
  id         Int           @id @default(autoincrement())
  pedido     Pedido        @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId   Int
  metodo     PaymentMethod
  montoCents Int
  referencia String?
  createdAt  DateTime       @default(now())
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  rol       String   // admin, cajero, mesero
  activo    Boolean  @default(true)
  passwordHash String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]
  pedidos   Pedido[]
}

// Ajustes de la aplicación (singleton)
model Ajustes {
  id            Int     @id @default(1)
  locale        String  @default("es-ES")
  currency      String  @default("EUR")
  taxPct        Int     @default(0)
  propinaPct    Int     @default(0)
  businessName  String  @default("Mi Restaurante")
  businessAddress String?
  businessRnc   String?
  businessPhone String?
  ticketFooter  String  @default("¡Gracias por su compra!")
  logoUrl       String  @default("/logo.png")
  // Impresoras
  printerIp     String?
  printerPort   Int?    @default(9100)
  serialBaud    Int?    @default(115200)
  autoKitchenOnCreate Boolean @default(false)
  autoKitchenOnReady  Boolean @default(false)
  touchMode     Boolean @default(false)
  updatedAt     DateTime @updatedAt
}

// Sesiones para autenticación con cookies
model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  user      Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Auditoría de accesos a tickets (opcional)
model TicketAccess {
  id        Int      @id @default(autoincrement())
  pedido    Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId  Int
  at        DateTime @default(now())
  ip        String?
  signed    Boolean  @default(false)
}

// Mapeo de menú para integraciones (UberEats, PedidosYa)
model IntegrationMapping {
  id              Int      @id @default(autoincrement())
  platform        String   // "ubereats", "pedidosya"
  producto        Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  productoId      Int
  externalItemId  String   // El ID del artículo en el sistema de Uber/PedidosYa
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([platform, productoId])
  @@unique([platform, externalItemId])
}

// --- Módulo de Inventario y Recetario ---

model Insumo {
  id           Int       @id @default(autoincrement())
  nombre       String    @unique
  stockActual  Float     @default(0) // Puede tener decimales (ej. 1.5 Litros)
  unidadMedida String    // "Unidad", "Gramos", "Litros", "Mililitros", "Kilogramos"
  costoCents   Int       @default(0) // Costo por unidadMedida
  stockMinimo  Float     @default(0) // Para alertas de bajo stock
  activo       Boolean   @default(true)
  diasVidaUtil Int       @default(365) // Días de caducidad
  proveedor    Proveedor? @relation(fields: [proveedorId], references: [id])
  proveedorId  Int?
  recetaItems  RecetaItem[]
  movimientos  MovimientoInventario[]
  ordenesItems OrdenCompraItem[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model RecetaItem {
  id                Int      @id @default(autoincrement())
  producto          Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  productoId        Int
  insumo            Insumo   @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  insumoId          Int
  cantidadRequerida Float    // Cantidad de la unidadMedida del insumo que se requiere
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([productoId, insumoId])
}

model MovimientoInventario {
  id          Int      @id @default(autoincrement())
  insumo      Insumo   @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  insumoId    Int
  tipo        String   // "ENTRADA" (Compra), "SALIDA" (Venta/Merma), "AJUSTE"
  cantidad    Float    // Cantidad sumada o restada
  razon       String?  // Ej. "Venta Pedido #123", "Compra a proveedor X"
  usuarioId   Int?     // Quién registró (opcional si es automático)
  createdAt   DateTime @default(now())
}

model Proveedor {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  contacto    String?
  telefono    String?
  email       String?
  rnc         String?
  diasEntrega Int       @default(1)
  activo      Boolean   @default(true)
  insumos     Insumo[]
  ordenes     OrdenCompra[]
  documentosPorPagar DocumentoPorPagar[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model OrdenCompra {
  id            Int               @id @default(autoincrement())
  proveedor     Proveedor         @relation(fields: [proveedorId], references: [id])
  proveedorId   Int
  estado        String            @default("BORRADOR") // BORRADOR, ENVIADA, RECIBIDA, CANCELADA
  totalCents    Int               @default(0)
  fechaEsperada DateTime?
  items         OrdenCompraItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  ncf            String?
  ncfTipo        String?
  registroFiscal RegistroFiscal?
}

model OrdenCompraItem {
  id                 Int         @id @default(autoincrement())
  orden              OrdenCompra @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  ordenId            Int
  insumo             Insumo      @relation(fields: [insumoId], references: [id])
  insumoId           Int
  cantidadPedida     Float
  cantidadRecibida   Float       @default(0)
  costoUnitarioCents Int
  totalCents         Int
}

// --- Módulo de Nómina ---

model Empleado {
  id              Int       @id @default(autoincrement())
  codigo          String    @unique                       // Ej: "EMP-001"
  nombre          String
  apellido        String
  cedula          String    @unique                       // Cédula de identidad
  fechaNacimiento DateTime?
  sexo            String?                                 // "M", "F"
  direccion       String?
  telefono        String?
  email           String?

  // --- Datos Laborales ---
  cargo           String                                  // "Cocinero", "Cajero", "Mesero", etc.
  departamento    String    @default("Operaciones")       // "Cocina", "Servicio", "Admin"
  tipoContrato    String    @default("INDEFINIDO")        // INDEFINIDO, TEMPORAL, PRUEBA
  fechaIngreso    DateTime
  fechaSalida     DateTime?
  activo          Boolean   @default(true)

  // --- Compensación ---
  salarioBaseCents Int                                    // Salario mensual en centavos
  tipoSalario     String    @default("QUINCENAL")        // MENSUAL, QUINCENAL
  cuentaBanco     String?
  banco           String?

  // --- Seguridad Social ---
  nss             String?   @unique                       // Número de Seguridad Social (TSS)
  afpId           String?                                 // ID en la AFP

  // --- Relaciones ---
  nominas         Nomina[]
  asistencias     Asistencia[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Nomina {
  id              Int       @id @default(autoincrement())
  periodo         String                                  // "2026-05-Q1" (año-mes-quincena)
  tipo            String    @default("ORDINARIA")         // ORDINARIA, EXTRAORDINARIA, REGALIA
  estado          String    @default("BORRADOR")          // BORRADOR, CALCULADA, APROBADA, PAGADA

  empleado        Empleado  @relation(fields: [empleadoId], references: [id])
  empleadoId      Int

  // --- Ingresos ---
  salarioBaseCents     Int                                // Salario base del periodo (quincenal)
  horasExtrasCents     Int   @default(0)                  // Total horas extras
  comisionesCents      Int   @default(0)
  bonosCents           Int   @default(0)
  propinaCents         Int   @default(0)                  // Propinas del periodo (Art. 228 CT — NO es salario)
  otrosIngresosCents   Int   @default(0)
  totalDevengadoSalarialCents Int @default(0)              // Solo ingresos salariales (sin propina)
  totalDevengadoCents  Int   @default(0)                  // Incluye propina (referencia)

  // --- Deducciones Legales ---
  sfsCents             Int   @default(0)                  // SFS empleado (3.04%)
  afpCents             Int   @default(0)                  // AFP empleado (2.87%)
  isrCents             Int   @default(0)                  // ISR retenido
  totalDeduccionesLegalesCents Int @default(0)

  // --- Deducciones Voluntarias ---
  adelantoCents        Int   @default(0)
  otrasDeduccionesCents Int  @default(0)
  totalDeduccionesCents Int  @default(0)                  // Total deducciones

  // --- Aportes Patronales (info, no se descuenta al empleado) ---
  sfsPatronalCents     Int   @default(0)                  // SFS patronal (7.09%)
  afpPatronalCents     Int   @default(0)                  // AFP patronal (7.10%)
  srlCents             Int   @default(0)                  // SRL (1.0-1.6%)
  infotepCents         Int   @default(0)                  // INFOTEP (1%)
  totalPatronalCents   Int   @default(0)

  // --- Neto ---
  salarioNetoCents     Int   @default(0)                  // Salario neto sin propina
  totalRecibirCents    Int   @default(0)                  // Salario neto + propina = total a recibir

  // --- Horas extras desglosadas ---
  horasExtraDiurnas    Float @default(0)
  horasExtraNocturnas  Float @default(0)
  horasExtraFeriado    Float @default(0)

  notas           String?
  fechaPago       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  transaccionId   Int?
  transaccion     TransaccionContable? @relation(fields: [transaccionId], references: [id])

  @@unique([empleadoId, periodo, tipo])
}

// Skeleton para control de asistencia (implementación futura)
model Asistencia {
  id              Int       @id @default(autoincrement())
  empleado        Empleado  @relation(fields: [empleadoId], references: [id])
  empleadoId      Int

  fecha           DateTime
  horaEntrada     DateTime?
  horaSalida      DateTime?
  horasTrabajadas Float     @default(0)
  horasExtras     Float     @default(0)
  tipoExtra       String?                                 // "DIURNA", "NOCTURNA", "FERIADO"
  ausencia        String?                                 // "JUSTIFICADA", "INJUSTIFICADA", "VACACIONES", "LICENCIA"
  notas           String?

  createdAt       DateTime  @default(now())
}

// Configuración de nómina (singleton, parámetros legales actualizables)
model ConfigNomina {
  id              Int       @id @default(1)

  // Tasas empleado
  sfsPct          Float     @default(3.04)
  afpPct          Float     @default(2.87)

  // Tasas patronal
  sfsPatronalPct  Float     @default(7.09)
  afpPatronalPct  Float     @default(7.10)
  srlPct          Float     @default(1.00)
  infotepPct      Float     @default(1.00)

  // Topes cotizables (en centavos)
  topeSfsCents    Int       @default(23223000)   // RD$ 232,230.00
  topeAfpCents    Int       @default(46446000)   // RD$ 464,460.00
  topeSrlCents    Int       @default(9289200)    // RD$ 92,892.00

  // ISR - Escalas (anuales en centavos)
  isrExentoCents       Int  @default(41622000)   // RD$ 416,220.00
  isrTramo1LimiteCents Int  @default(62432900)   // RD$ 624,329.00
  isrTramo2LimiteCents Int  @default(86712300)   // RD$ 867,123.00
  isrTramo1Pct         Float @default(15)
  isrTramo2Pct         Float @default(20)
  isrTramo3Pct         Float @default(25)
  isrTramo1FijoCents   Int  @default(3121600)    // RD$ 31,216.00
  isrTramo2FijoCents   Int  @default(7977600)    // RD$ 79,776.00

  // Horas extras
  recargoExtraDiurna   Float @default(35)        // 35%
  recargoExtraNocturna Float @default(54)        // ~54%
  recargoFeriado       Float @default(100)       // 100%

  // Jornada
  horasSemanales       Float @default(44)
  horasDiarias         Float @default(8)

  // Distribución de propinas por departamento (JSON)
  // Ej: {"Servicio":40,"Cocina":35,"Barra":15,"Auxiliar":10}
  propinaDistribucion  String @default("{\"Servicio\":40,\"Cocina\":35,\"Barra\":15,\"Auxiliar\":10}")

  updatedAt       DateTime  @updatedAt
}

// --- MÓDULO DE CONTABILIDAD ---

model CuentaContable {
  id            Int              @id @default(autoincrement())
  codigo        String           @unique // Ej. "1.1.01.01" (Activo - Corriente - Efectivo - Caja Chica)
  nombre        String
  tipo          String           // "ACTIVO", "PASIVO", "PATRIMONIO", "INGRESO", "COSTO", "GASTO"
  naturaleza    String           // "DEBITO" o "CREDITO"
  activa        Boolean          @default(true)
  padreId       Int?
  padre         CuentaContable?  @relation("Jerarquia", fields: [padreId], references: [id])
  subCuentas    CuentaContable[] @relation("Jerarquia")
  apuntes       ApunteContable[]
  cuentasBancarias CuentaBancaria[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model TransaccionContable {
  id          Int              @id @default(autoincrement())
  numero      String           @unique // Ej. "AS-2026-05-0001"
  fecha       DateTime
  glDate      DateTime         @default(now())
  descripcion String
  estado      String           @default("BORRADOR") // "BORRADOR", "POSTEADO", "ANULADO"
  referencia  String?          // Ej: "Pedido #1024"
  origen      String?          // "POS", "NOMINA", "COMPRAS", "MANUAL"
  apuntes     ApunteContable[]
  nominas     Nomina[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ApunteContable {
  id            Int                 @id @default(autoincrement())
  transaccion   TransaccionContable @relation(fields: [transaccionId], references: [id], onDelete: Cascade)
  transaccionId Int
  cuenta        CuentaContable      @relation(fields: [cuentaId], references: [id])
  cuentaId      Int
  debitoCents   Int                 @default(0)
  creditoCents  Int                 @default(0)
  referencia    String?
}

// --- MÓDULO CONTROL FISCAL Y DGII ---

model SecuenciaNcf {
  id            Int      @id @default(autoincrement())
  tipo          String   // "B01", "B02", "B14", "B15"
  prefijo       String   // "B"
  tipoCodigo    String   // "01", "02", "14", "15"
  inicio        Int
  fin           Int
  actual        Int
  vencimiento   DateTime
  activa        Boolean  @default(true)
  descripcion   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RegistroFiscal {
  id              Int      @id @default(autoincrement())
  tipo            String   // "COMPRA" o "VENTA"
  rncCedula       String
  tipoId          Int
  tipoGasto       String?
  ncf             String
  ncfModificado   String?
  fechaComprobante DateTime
  fechaPago       DateTime?
  montoFacturadoCents Int
  itebisFacturadoCents Int     @default(0)
  itebisRetenidoCents  Int     @default(0)
  itebisSujetoProporcionalidadCents Int @default(0)
  itebisLlevadoCostoCents Int  @default(0)
  itebisPorAdelantarCents Int  @default(0)
  itebisPercibidoCents Int     @default(0)
  isrRetenidoCents     Int     @default(0)
  tipoRetencionIsr    String?
  impuestoSelectivoConsumoCents Int @default(0)
  otrosImpuestosCents  Int     @default(0)
  propinaLegalCents    Int     @default(0)
  
  montoEfectivoCents   Int     @default(0)
  montoTarjetaCents    Int     @default(0)
  montoCreditoCents    Int     @default(0)
  montoTransferenciaCents Int  @default(0)
  otrasFormasPagoCents Int     @default(0)

  pedidoId        Int?     @unique
  pedido          Pedido?  @relation(fields: [pedidoId], references: [id])
  ordenCompraId   Int?     @unique
  ordenCompra     OrdenCompra? @relation(fields: [ordenCompraId], references: [id])
  
  estado          String   @default("ACTIVO")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NcfAnulado {
  id              Int      @id @default(autoincrement())
  ncf             String   @unique
  fechaComprobante DateTime
  fechaAnulacion  DateTime @default(now())
  tipoAnulacion   String
  comentario      String?
  createdAt       DateTime @default(now())
}

// --- MÓDULO DE TESORERÍA ---

model CuentaBancaria {
  id              Int       @id @default(autoincrement())
  nombre          String    // "Banco Popular - Cuenta Corriente"
  banco           String    // "Banco Popular", "Banreservas", etc.
  tipoCuenta      String    // "CORRIENTE", "AHORRO"
  numeroCuenta    String?   // Últimos 4 dígitos o completo
  cuentaContableId Int      // Vincula a CuentaContable (ej: 1.1.01.02)
  cuentaContable  CuentaContable @relation(fields: [cuentaContableId], references: [id])
  activa          Boolean   @default(true)
  movimientos     MovimientoBanco[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model MovimientoBanco {
  id               Int            @id @default(autoincrement())
  cuentaBancaria   CuentaBancaria @relation(fields: [cuentaBancariaId], references: [id])
  cuentaBancariaId Int
  tipo             String         // "DEPOSITO", "RETIRO", "TRANSFERENCIA_IN", "TRANSFERENCIA_OUT", "PAGO_CXP", "COBRO_CXC"
  montoCents       Int
  descripcion      String
  referencia       String?        // Ej: "Pedido #123", "Cheque #456"
  fecha            DateTime       @default(now())
  createdAt        DateTime       @default(now())
}

model DocumentoPorPagar {
  id               Int       @id @default(autoincrement())
  proveedorId      Int?
  proveedor        Proveedor? @relation(fields: [proveedorId], references: [id])
  ordenCompraId    Int?
  categoria        String    @default("INVENTARIO") // INVENTARIO, ALQUILER, SERVICIOS, NOMINA, IMPUESTOS, OTROS
  descripcion      String    // "Factura #123 - Alquiler local"
  ncf              String?
  montoCents       Int       // Monto total de la deuda
  pagadoCents      Int       @default(0) // Cuánto se ha pagado
  estado           String    @default("PENDIENTE") // PENDIENTE, PARCIAL, PAGADO
  fechaVencimiento DateTime?
  fechaDocumento   DateTime  @default(now())
  pagos            PagoCXP[]
  facturaEscaneadaUrl String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model PagoCXP {
  id          Int               @id @default(autoincrement())
  documento   DocumentoPorPagar @relation(fields: [documentoId], references: [id])
  documentoId Int
  montoCents  Int
  metodoPago  String            // "EFECTIVO", "TRANSFERENCIA", "CHEQUE"
  referencia  String?           // Número de cheque, referencia bancaria
  fecha       DateTime          @default(now())
  createdAt   DateTime          @default(now())
}

model DocumentoPorCobrar {
  id               Int       @id @default(autoincrement())
  clienteNombre    String
  clienteRnc       String?
  clienteTelefono  String?
  pedidoId         Int?
  descripcion      String
  ncf              String?
  montoCents       Int
  cobradoCents     Int       @default(0)
  estado           String    @default("PENDIENTE") // PENDIENTE, PARCIAL, COBRADO
  fechaVencimiento DateTime?
  fechaDocumento   DateTime  @default(now())
  cobros           CobroCXC[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model CobroCXC {
  id          Int                @id @default(autoincrement())
  documento   DocumentoPorCobrar @relation(fields: [documentoId], references: [id])
  documentoId Int
  montoCents  Int
  metodoPago  String             // "EFECTIVO", "TRANSFERENCIA", "TARJETA"
